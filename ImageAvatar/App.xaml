<Application
    x:Class="ImageAvatar.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ImageAvatar.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- Default language loaded at runtime by LocalizationService -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available application-wide -->
            <BooleanToVisibilityConverter                        x:Key="BoolToVis" />
            <converters:InverseBoolToVisibilityConverter         x:Key="InverseBoolToVis" />
            <converters:NotEmptyToVisibilityConverter            x:Key="NotEmptyToVis" />
            <converters:BoolToBrushConverter                     x:Key="BoolToBrush" />
            <converters:BoolToControlAppearanceConverter         x:Key="BoolToAppearance" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
