<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <sys:String x:Key="AppTitle">ImageAvatar</sys:String>

    <!-- Navigation -->
    <sys:String x:Key="NavDashboard">Dashboard</sys:String>
    <sys:String x:Key="NavSettings">Settings</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnRefresh">Refresh</sys:String>
    <sys:String x:Key="BtnWatch">Watch</sys:String>
    <sys:String x:Key="BtnApply">Apply</sys:String>
    <sys:String x:Key="BtnOpenFolder">Open Folder</sys:String>

    <!-- Dashboard -->
    <sys:String x:Key="LabelRootPath">Root Path</sys:String>

    <!-- Pipeline Folder Labels -->
    <sys:String x:Key="FolderExtractQueue">Extract Queue</sys:String>
    <sys:String x:Key="FolderExtractDone">Extract Done</sys:String>
    <sys:String x:Key="FolderRefineQueue">Refine Queue</sys:String>
    <sys:String x:Key="FolderRefineDone">Refine Done</sys:String>
    <sys:String x:Key="FolderFinalizeQueue">Finalize Queue</sys:String>
    <sys:String x:Key="FolderFinalizeDone">Finalize Done</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsLanguageHeader">Language</sys:String>
    <sys:String x:Key="SettingsLanguageDesc">Select the display language for the application.</sys:String>
    <sys:String x:Key="SettingsThemeHeader">Theme</sys:String>
    <sys:String x:Key="SettingsThemeDesc">Switch between Dark and Light mode.</sys:String>

</ResourceDictionary>
