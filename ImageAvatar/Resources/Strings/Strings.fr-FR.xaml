<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <sys:String x:Key="AppTitle">ImageAvatar</sys:String>

    <!-- Navigation -->
    <sys:String x:Key="NavDashboard">Tableau de bord</sys:String>
    <sys:String x:Key="NavSettings">Paramètres</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnRefresh">Actualiser</sys:String>
    <sys:String x:Key="BtnWatch">Surveiller</sys:String>
    <sys:String x:Key="BtnApply">Appliquer</sys:String>
    <sys:String x:Key="BtnOpenFolder">Ouvrir le dossier</sys:String>

    <!-- Dashboard -->
    <sys:String x:Key="LabelRootPath">Dossier racine</sys:String>

    <!-- Pipeline Folder Labels -->
    <sys:String x:Key="FolderExtractQueue">File d'extraction</sys:String>
    <sys:String x:Key="FolderExtractDone">Extraction terminée</sys:String>
    <sys:String x:Key="FolderRefineQueue">File de détourage</sys:String>
    <sys:String x:Key="FolderRefineDone">Détourage terminé</sys:String>
    <sys:String x:Key="FolderFinalizeQueue">File de finalisation</sys:String>
    <sys:String x:Key="FolderFinalizeDone">Finalisation terminée</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsLanguageHeader">Langue</sys:String>
    <sys:String x:Key="SettingsLanguageDesc">Sélectionner la langue d'affichage de l'application.</sys:String>
    <sys:String x:Key="SettingsThemeHeader">Thème</sys:String>
    <sys:String x:Key="SettingsThemeDesc">Basculer entre le mode sombre et le mode clair.</sys:String>

</ResourceDictionary>
