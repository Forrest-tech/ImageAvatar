<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <sys:String x:Key="AppTitle">图像头像</sys:String>

    <!-- Navigation -->
    <sys:String x:Key="NavDashboard">仪表盘</sys:String>
    <sys:String x:Key="NavSettings">设置</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnRefresh">刷新</sys:String>
    <sys:String x:Key="BtnWatch">监控</sys:String>
    <sys:String x:Key="BtnApply">应用</sys:String>
    <sys:String x:Key="BtnOpenFolder">打开文件夹</sys:String>

    <!-- Dashboard -->
    <sys:String x:Key="LabelRootPath">根目录</sys:String>

    <!-- Pipeline Folder Labels -->
    <sys:String x:Key="FolderExtractQueue">提图队列</sys:String>
    <sys:String x:Key="FolderExtractDone">提图完成</sys:String>
    <sys:String x:Key="FolderRefineQueue">抠图队列</sys:String>
    <sys:String x:Key="FolderRefineDone">抠图完成</sys:String>
    <sys:String x:Key="FolderFinalizeQueue">成品队列</sys:String>
    <sys:String x:Key="FolderFinalizeDone">成品完成</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsLanguageHeader">语言</sys:String>
    <sys:String x:Key="SettingsLanguageDesc">选择应用程序的显示语言。</sys:String>
    <sys:String x:Key="SettingsThemeHeader">主题</sys:String>
    <sys:String x:Key="SettingsThemeDesc">在深色和浅色模式之间切换。</sys:String>

</ResourceDictionary>
