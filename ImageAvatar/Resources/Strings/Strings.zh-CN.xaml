    <sys:String x:Key="NavQc">质检审核</sys:String>
    <sys:String x:Key="NavSettings">设置</sys:String>
    <sys:String x:Key="NavConsole">控制台输出</sys:String>

    <sys:String x:Key="BtnRefresh">刷新</sys:String>
    <sys:String x:Key="BtnWatch">监控</sys:String>
    <sys:String x:Key="BtnOpenWorkspace">打开工作区</sys:String>
    <sys:String x:Key="BtnStartService">启动服务</sys:String>
    <sys:String x:Key="BtnStopService">停止服务</sys:String>
    <sys:String x:Key="BtnApply">应用</sys:String>
    <sys:String x:Key="BtnOpenFolder">打开文件夹</sys:String>
    <sys:String x:Key="BtnBrowse">浏览…</sys:String>
    <sys:String x:Key="BtnLoadModel">加载模型</sys:String>
    <sys:String x:Key="BtnStartBatch">开始批处理</sys:String>
    <sys:String x:Key="BtnCancelBatch">取消</sys:String>

