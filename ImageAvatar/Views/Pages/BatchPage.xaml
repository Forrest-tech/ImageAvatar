<ui:Page
    x:Class="ImageAvatar.Views.Pages.BatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:BatchProcessorViewModel}"
    Scrollable="True">

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Row 0: Page header ─────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBlock
                Text="{DynamicResource NavBatch}"
                FontTypography="TitleLarge"
                Margin="0,0,16,0" />
            <ui:Button
                Content="{DynamicResource BtnStartBatch}"
                Command="{Binding StartBatchCommand}"
                Icon="{ui:SymbolIcon Symbol=PlayCircle24}"
                Appearance="Primary"
                VerticalAlignment="Center" />
            <ui:Button
                Content="{DynamicResource BtnCancelBatch}"
                Command="{Binding CancelBatchCommand}"
                Icon="{ui:SymbolIcon Symbol=Stop24}"
                Appearance="Secondary"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Visibility="{Binding IsBatchRunning, Converter={StaticResource BoolToVis}}" />
            <ui:ProgressRing
                IsIndeterminate="True"
                Width="20" Height="20"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Visibility="{Binding IsBatchRunning, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- ── Row 1: Templates folder ───────────────────────────────── -->
        <ui:Card Grid.Row="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock
                    Grid.Column="0"
                    Text="{DynamicResource LabelTemplatesFolder}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />
                <ui:TextBox
                    Grid.Column="1"
                    Text="{Binding TemplatesFolder, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="C:\Work\ImageAvatar\templates"
                    VerticalAlignment="Center" />
                <ui:Button
                    Grid.Column="2"
                    Content="{DynamicResource BtnBrowse}"
                    Command="{Binding BrowseTemplatesFolderCommand}"
                    Appearance="Secondary"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center" />
            </Grid>
        </ui:Card>

        <!-- ── Row 2: Progress card (while running) ───────────────────── -->
        <ui:Card
            Grid.Row="2"
            Margin="0,0,0,12"
            Visibility="{Binding IsBatchRunning, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <ui:SymbolIcon Symbol="Image24" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ui:TextBlock
                        Text="{Binding BatchStatus}"
                        FontTypography="BodyStrong"
                        VerticalAlignment="Center" />
                </StackPanel>
                <ProgressBar
                    Grid.Row="1"
                    Value="{Binding BatchProgress}"
                    Maximum="1.0"
                    Height="6"
                    Margin="0,0,0,4" />
                <ui:TextBlock
                    Grid.Row="2"
                    Text="{Binding ProgressSummary}"
                    Opacity="0.65"
                    FontSize="11" />
            </Grid>
        </ui:Card>

        <!-- ── Row 3: Last status (after run) ────────────────────────── -->
        <ui:Card
            Grid.Row="3"
            Margin="0,0,0,12"
            Visibility="{Binding BatchStatus, Converter={StaticResource NotEmptyToVis}}">
            <ui:TextBlock
                Text="{Binding BatchStatus}"
                Opacity="0.65"
                FontSize="11"
                Visibility="{Binding IsBatchRunning, Converter={StaticResource InverseBoolToVis}}" />
        </ui:Card>

        <!-- ── Row 4: Stats row (after run) ──────────────────────────── -->
        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            Margin="0,0,0,12"
            Visibility="{Binding IsBatchRunning, Converter={StaticResource InverseBoolToVis}}">
            <Border Background="#1B5E20" CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                    Visibility="{Binding CompletedCount, Converter={StaticResource NotEmptyToVis}}">
                <StackPanel Orientation="Horizontal">
                    <ui:TextBlock Text="{Binding CompletedCount}" FontSize="12" FontWeight="Bold" Margin="0,0,4,0" />
                    <ui:TextBlock Text="{DynamicResource LabelBatchCompleted}" FontSize="12" />
                </StackPanel>
            </Border>
            <Border Background="#B71C1C" CornerRadius="4" Padding="8,3"
                    Visibility="{Binding FailedCount, Converter={StaticResource NotEmptyToVis}}">
                <StackPanel Orientation="Horizontal">
                    <ui:TextBlock Text="{Binding FailedCount}" FontSize="12" FontWeight="Bold" Margin="0,0,4,0" />
                    <ui:TextBlock Text="{DynamicResource LabelBatchFailed}" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── Row 5: Results list ────────────────────────────────────── -->
        <ItemsControl Grid.Row="5" ItemsSource="{Binding BatchItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        BorderThickness="0,0,0,1"
                        Padding="4,8"
                        Margin="0,0,0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Success / fail icon -->
                            <ui:SymbolIcon
                                Grid.Column="0"
                                Symbol="Checkmark24"
                                Foreground="#4CAF50"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding Success, Converter={StaticResource BoolToVis}}" />
                            <ui:SymbolIcon
                                Grid.Column="0"
                                Symbol="ErrorCircle24"
                                Foreground="#F44336"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding Success, Converter={StaticResource InverseBoolToVis}}" />

                            <!-- Names + error -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ui:TextBlock
                                    FontTypography="BodyStrong"
                                    Text="{Binding PatternName}" />
                                <ui:TextBlock
                                    Text="{Binding TemplateName}"
                                    Opacity="0.6"
                                    FontSize="11" />
                                <ui:TextBlock
                                    Text="{Binding ErrorMessage}"
                                    Foreground="#F44336"
                                    FontSize="11"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVis}}" />
                            </StackPanel>

                            <!-- Elapsed -->
                            <ui:TextBlock
                                Grid.Column="2"
                                Text="{Binding ElapsedText}"
                                Opacity="0.5"
                                FontSize="11"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</ui:Page>
