<UserControl
    x:Class="ImageAvatar.Views.Pages.SynthesisConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SynthesisConfigViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: parameters ── -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="自动合成配置" FontSize="22" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="模板文件夹" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding TemplatesFolder}"
                                        IsReadOnly="True"
                                        PlaceholderText="Mockup 模板所在文件夹" />
                            <ui:Button Grid.Column="2" Content="浏览"
                                       Appearance="Secondary"
                                       Command="{Binding BrowseTemplatesCommand}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="合成选项" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="保持宽高比（保留图案原始比例）"
                                  IsChecked="{Binding PreserveAspectRatio}"
                                  Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="输出质量" VerticalAlignment="Center"
                                       Width="90" Margin="0,0,8,0" />
                            <Slider Minimum="60" Maximum="100"
                                    Value="{Binding OutputQuality}"
                                    Width="200"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="{Binding OutputQuality, StringFormat={}{0}%}"
                                       VerticalAlignment="Center" Width="36" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="保存配置" Appearance="Primary"
                               Command="{Binding SaveCommand}"
                               Margin="0,0,12,0" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- ── Right: info panel ── -->
            <ui:Card Grid.Column="2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="说明" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="自动合成将抠图后的图案与 Mockup 模板叠加，使用 Multiply 混合模式保留布料纹理。&#x0a;&#x0a;• 模板文件夹：存放 .png 格式 Mockup 模板&#x0a;• 输出质量：影响 JPEG 输出的压缩比" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
