<UserControl
    x:Class="ImageAvatar.Views.Pages.CropConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:CropConfigViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: parameters ── -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="自动裁剪配置" FontSize="22" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="输出尺寸" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="最小宽度" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding MinWidth, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="像素" />
                            <TextBlock Grid.Column="3" Text="最小高度" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Column="4"
                                        Text="{Binding MinHeight, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="像素" />
                        </Grid>
                        <CheckBox Content="强制正方形输出" IsChecked="{Binding SquareOutput}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="裁剪选项" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="边距比例" VerticalAlignment="Center" Width="80" Margin="0,0,8,0" />
                            <Slider Minimum="0" Maximum="0.2"
                                    Value="{Binding PaddingRatio}"
                                    Width="200"
                                    TickFrequency="0.01"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="{Binding PaddingRatio, StringFormat={}{0:P0}}"
                                       VerticalAlignment="Center" Width="40" />
                        </StackPanel>
                        <CheckBox Content="自动旋转（根据长边方向）" IsChecked="{Binding AutoRotate}" />
                    </StackPanel>
                </ui:Card>

                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="保存配置" Appearance="Primary"
                               Command="{Binding SaveCommand}"
                               Margin="0,0,12,0" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- ── Right: info panel ── -->
            <ui:Card Grid.Column="2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="说明" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="自动裁剪服务监听提图队列，将输入图片智能裁剪至指定尺寸。&#x0a;&#x0a;• 边距比例：在裁剪框四周额外保留的留白比例&#x0a;• 正方形输出：强制宽高相等，适合 POD 平台上传规格" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
