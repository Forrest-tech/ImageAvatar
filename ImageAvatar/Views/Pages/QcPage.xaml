<ui:Page
    x:Class="ImageAvatar.Views.Pages.QcPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:models="clr-namespace:ImageAvatar.Models"
    xmlns:controls="clr-namespace:ImageAvatar.Controls"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:QcViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Row 0 : Toolbar ────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="24,14,24,10">
            <StackPanel Orientation="Horizontal">

                <ui:TextBlock
                    Text="{DynamicResource NavQc}"
                    FontTypography="TitleLarge"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0" />

                <!-- Mode: Grid -->
                <ui:Button
                    Content="{DynamicResource BtnGridMode}"
                    Command="{Binding SetGridModeCommand}"
                    Appearance="{Binding IsGridMode, Converter={StaticResource BoolToAppearance}}"
                    Icon="{ui:SymbolIcon Symbol=Grid24}"
                    VerticalAlignment="Center" />

                <!-- Mode: Overlay -->
                <ui:Button
                    Content="{DynamicResource BtnOverlayMode}"
                    Command="{Binding SetOverlayModeCommand}"
                    Appearance="{Binding IsOverlayMode, Converter={StaticResource BoolToAppearance}}"
                    Icon="{ui:SymbolIcon Symbol=LayerDiagonalPerson24}"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center" />

                <!-- Reset zoom -->
                <ui:Button
                    Content="{DynamicResource BtnResetZoom}"
                    Command="{Binding ResetZoomCommand}"
                    Icon="{ui:SymbolIcon Symbol=ZoomIn24}"
                    Appearance="Secondary"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center" />

                <!-- Refresh list -->
                <ui:Button
                    Content="{DynamicResource BtnRefresh}"
                    Command="{Binding LoadItemsCommand}"
                    Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                    Appearance="Secondary"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center" />

                <!-- Loading indicator -->
                <ui:ProgressRing
                    IsIndeterminate="True"
                    Width="18" Height="18"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

            </StackPanel>
        </Border>

        <!-- ── Row 1 : Main split ─────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="200" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Left : item list ──────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Summary bar -->
                <Border Grid.Row="0" Padding="12,6" Margin="0,0,0,4">
                    <ui:TextBlock
                        Text="{Binding ItemCountSummary}"
                        FontSize="11"
                        Opacity="0.6" />
                </Border>

                <!-- Empty-state placeholder -->
                <ui:TextBlock
                    Grid.Row="1"
                    Text="{DynamicResource LabelNoQcItems}"
                    Opacity="0.45"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding QcItems.Count,
                        Converter={StaticResource NotEmptyToVis},
                        ConverterParameter=Inverse}" />

                <!-- Item list -->
                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding QcItems}"
                    SelectedItem="{Binding SelectedItem}"
                    HorizontalContentAlignment="Stretch"
                    BorderThickness="0"
                    VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,4" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:QcItem}">
                            <Grid Margin="2,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Filename -->
                                <ui:TextBlock
                                    Grid.Row="0"
                                    Text="{Binding FileName}"
                                    FontTypography="BodyStrong"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding MockupPath}"
                                    Margin="0,0,0,3" />

                                <!-- Status badge -->
                                <TextBlock Grid.Row="1" FontSize="11" Margin="0,0,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{DynamicResource LabelQcPending}" />
                                            <Setter Property="Foreground" Value="#FF9800" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="{x:Static models:QcStatus.Approved}">
                                                    <Setter Property="Text"       Value="{DynamicResource LabelQcApproved}" />
                                                    <Setter Property="Foreground" Value="#4CAF50" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="{x:Static models:QcStatus.Rejected}">
                                                    <Setter Property="Text"       Value="{DynamicResource LabelQcRejected}" />
                                                    <Setter Property="Foreground" Value="#F44336" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Approve / Reject buttons (only while Pending) -->
                                <StackPanel
                                    Grid.Row="2"
                                    Orientation="Horizontal"
                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                                    <ui:Button
                                        Content="{DynamicResource BtnApprove}"
                                        Command="{Binding DataContext.ApproveCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Success"
                                        Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                                        Padding="8,4" />
                                    <ui:Button
                                        Content="{DynamicResource BtnReject}"
                                        Command="{Binding DataContext.RejectCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Danger"
                                        Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                        Margin="6,0,0,0"
                                        Padding="8,4" />
                                </StackPanel>

                                <!-- Decision label after decision is made -->
                                <ui:TextBlock
                                    Grid.Row="2"
                                    FontSize="11"
                                    Opacity="0.55"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding IsPending,
                                        Converter={StaticResource InverseBoolToVis}}">
                                    <ui:TextBlock.Style>
                                        <Style TargetType="ui:TextBlock">
                                            <Setter Property="Text" Value="" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="{x:Static models:QcStatus.Approved}">
                                                    <Setter Property="Text" Value="{DynamicResource LabelProductionReady}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="{x:Static models:QcStatus.Rejected}">
                                                    <Setter Property="Text" Value="{DynamicResource LabelRework}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:TextBlock.Style>
                                </ui:TextBlock>

                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- ── Column splitter ─────────────────────────────────────── -->
            <GridSplitter
                Grid.Column="1"
                Width="6"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Columns"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <!-- ── Right : canvas area ─────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Empty state – no item selected -->
                <ui:TextBlock
                    Text="{DynamicResource LabelSelectItem}"
                    Opacity="0.4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasSelectedItem,
                        Converter={StaticResource InverseBoolToVis}}" />

                <!-- Canvas views – shown when an item is selected -->
                <Grid Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">

                    <!-- ─── GRID MODE : three canvases ─────────────────── -->
                    <Grid Visibility="{Binding IsGridMode, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Original -->
                        <controls:ComparisonCanvas
                            Grid.Column="0"
                            Image="{Binding OriginalBitmap}"
                            Caption="{DynamicResource LabelOriginal}"
                            Transform="{Binding Transform}" />

                        <GridSplitter Grid.Column="1" Width="4"
                                      ResizeBehavior="BasedOnAlignment"
                                      HorizontalAlignment="Stretch" />

                        <!-- Extracted PNG -->
                        <controls:ComparisonCanvas
                            Grid.Column="2"
                            Image="{Binding PatternBitmap}"
                            Caption="{DynamicResource LabelExtractedPng}"
                            Transform="{Binding Transform}" />

                        <GridSplitter Grid.Column="3" Width="4"
                                      ResizeBehavior="BasedOnAlignment"
                                      HorizontalAlignment="Stretch" />

                        <!-- Final Mockup -->
                        <controls:ComparisonCanvas
                            Grid.Column="4"
                            Image="{Binding MockupBitmap}"
                            Caption="{DynamicResource LabelFinalMockup}"
                            Transform="{Binding Transform}" />
                    </Grid>

                    <!-- ─── OVERLAY MODE : single canvas + slider ──────── -->
                    <Grid Visibility="{Binding IsOverlayMode, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Overlay canvas: Original + PNG on top with opacity -->
                        <controls:ComparisonCanvas
                            Grid.Row="0"
                            Image="{Binding OriginalBitmap}"
                            OverlayImage="{Binding PatternBitmap}"
                            OverlayOpacity="{Binding OverlayOpacity}"
                            Caption="{DynamicResource LabelOriginal}"
                            Transform="{Binding Transform}" />

                        <!-- Opacity slider row -->
                        <Border Grid.Row="1" Padding="16,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="LayerDiagonalPerson24" Margin="0,0,8,0" />
                                <ui:TextBlock
                                    Text="{DynamicResource LabelOverlayOpacity}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0" />
                                <Slider
                                    Value="{Binding OverlayOpacity}"
                                    Minimum="0" Maximum="1"
                                    Width="240"
                                    VerticalAlignment="Center" />
                                <ui:TextBlock
                                    Text="{Binding OverlayOpacityPercent}"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0"
                                    Opacity="0.65"
                                    Width="42" />
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:Page>
