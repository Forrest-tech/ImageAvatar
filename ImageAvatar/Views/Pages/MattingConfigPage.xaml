<UserControl
    x:Class="ImageAvatar.Views.Pages.MattingConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MattingConfigViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: parameters ── -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="自动抠图配置" FontSize="22" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="AI 模型 (U-2-Net)" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding ModelPath}"
                                        PlaceholderText="u2net.onnx 文件路径"
                                        IsReadOnly="True" />
                            <ui:Button Grid.Column="2" Content="浏览"
                                       Appearance="Secondary"
                                       Command="{Binding BrowseModelCommand}" />
                            <ui:Button Grid.Column="4" Content="加载模型"
                                       Appearance="Primary"
                                       Command="{Binding LoadModelCommand}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing IsIndeterminate="{Binding IsLoading}"
                                            Width="18" Height="18"
                                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ModelStatus}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="抠图参数" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="置信度阈值" VerticalAlignment="Center"
                                       Width="90" Margin="0,0,8,0" />
                            <Slider Minimum="0.1" Maximum="0.9"
                                    Value="{Binding Threshold}"
                                    Width="200"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Threshold, StringFormat={}{0:F2}}"
                                       VerticalAlignment="Center" Width="36" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Button Content="保存配置" Appearance="Primary"
                           Command="{Binding SaveCommand}"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <!-- ── Right: info panel ── -->
            <ui:Card Grid.Column="2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="说明" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="使用 U-2-Net ONNX 模型（约 176 MB）自动去除图片背景。&#x0a;&#x0a;模型文件需手动下载并放置至指定路径后加载。&#x0a;&#x0a;置信度阈值越高，边缘越锐利，但细节保留越少；建议默认值 0.5。" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
