<UserControl
    x:Class="ImageAvatar.Views.Pages.GenConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:GenConfigViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: parameters ── -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="生图服务配置" FontSize="22" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="API 连接" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="API 地址" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="http://localhost:7860" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="留空则不使用认证" />
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="测试连接" Appearance="Secondary"
                                       Command="{Binding TestConnectionCommand}"
                                       Margin="0,0,8,0" />
                            <ui:ProgressRing IsIndeterminate="{Binding IsTesting}"
                                            Width="20" Height="20"
                                            Visibility="{Binding IsTesting, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="生成参数" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="采样步数" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding Steps, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="CFG Scale" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="0" Grid.Column="4"
                                        Text="{Binding CfgScale, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="输出宽度" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding OutputWidth, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="输出高度" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Row="2" Grid.Column="4"
                                        Text="{Binding OutputHeight, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Button Content="保存配置" Appearance="Primary"
                           Command="{Binding SaveCommand}"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <!-- ── Right: info panel ── -->
            <ui:Card Grid.Column="2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="说明" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="支持兼容 AUTOMATIC1111 WebUI REST API 的本地或远程服务（SD WebUI、ComfyUI 等）。&#x0a;&#x0a;• 采样步数建议 20–50&#x0a;• CFG Scale 建议 7–12&#x0a;• 点击「测试连接」验证服务是否可达" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
