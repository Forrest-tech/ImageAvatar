<UserControl
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>

        <!-- Large blue service toggle button -->
        <Style x:Key="ServiceBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A4BB5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A5BC8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A9E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Open Workspace button (smaller blue) -->
        <Style x:Key="WorkspaceBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A4BB5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A5BC8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A9E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid AllowDrop="True"
          DragOver="OnDragOver"
          DragEnter="OnDragEnter"
          DragLeave="OnDragLeave"
          Drop="OnDrop">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- ── Root path configuration ───────────────────────────────── -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock
                        Grid.Column="0"
                        Text="{DynamicResource LabelRootPath}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />
                    <ui:TextBox
                        Grid.Column="1"
                        Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{DynamicResource LabelDropHint}"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="2"
                        Content="{DynamicResource BtnBrowse}"
                        Command="{Binding BrowseSourceFolderCommand}"
                        Appearance="Secondary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="3"
                        Content="{DynamicResource BtnApply}"
                        Command="{Binding ApplyRootPathCommand}"
                        Appearance="Primary"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="4"
                        Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                        ToolTip="{DynamicResource BtnOpenFolder}"
                        Command="{Binding OpenFolderCommand}"
                        CommandParameter="{Binding RootPath}"
                        Appearance="Secondary"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="5"
                        Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                        ToolTip="{DynamicResource BtnRefresh}"
                        Command="{Binding RefreshCommand}"
                        Appearance="Secondary"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>

                <!-- ── Open Workspace row: button + path display ──────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Command="{Binding OpenFolderCommand}"
                        CommandParameter="{Binding RootPath}"
                        Style="{StaticResource WorkspaceBtnStyle}">
                        <TextBlock
                            Text="{DynamicResource BtnOpenWorkspace}"
                            FontSize="13" />
                    </Button>

                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding RootPath}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0"
                        Opacity="0.65"
                        FontSize="13"
                        TextTrimming="CharacterEllipsis" />
                </Grid>

                <!-- ── Drag-and-drop hint ────────────────────────────────────── -->
                <Border
                    x:Name="DropHintBorder"
                    Visibility="Collapsed"
                    BorderBrush="#4FC3F7"
                    BorderThickness="2"
                    CornerRadius="6"
                    Background="#0C4FC3F7"
                    Padding="12,10"
                    Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="FolderArrowRight24" Margin="0,0,8,0" Foreground="#4FC3F7" />
                        <ui:TextBlock
                            Text="{DynamicResource LabelDropHint}"
                            Foreground="#4FC3F7"
                            FontTypography="BodyStrong" />
                    </StackPanel>
                </Border>

                <!-- ── Model Ready badge ─────────────────────────────────────── -->
                <Border
                    Background="#1B5E20"
                    CornerRadius="4"
                    Padding="8,4"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"
                    Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="12"
                                       Foreground="#81C784" Margin="0,0,6,0" />
                        <ui:TextBlock Text="{DynamicResource LabelModelLoaded}" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- ── Auto-extraction service toggle ───────────────────────── -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="520" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Large blue toggle button -->
                    <Button
                        Grid.Column="0"
                        Command="{Binding ToggleWatchingCommand}"
                        Style="{StaticResource ServiceBtnStyle}">
                        <TextBlock
                            Text="{DynamicResource LabelToggleAutoExtractionService}"
                            FontSize="14"
                            FontWeight="SemiBold" />
                    </Button>

                    <!-- Status indicator -->
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="20,0,0,0">
                        <Ellipse
                            Width="9" Height="9"
                            Fill="{Binding IsWatching, Converter={StaticResource BoolToBrush}}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                        <TextBlock
                            Text="{Binding ServiceStatusText}"
                            VerticalAlignment="Center"
                            FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                            <Setter Property="Foreground" Value="#81C784" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── Extraction progress (while running) ───────────────────── -->
                <ui:Card
                    Margin="0,0,0,10"
                    Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <ui:SymbolIcon Symbol="Image24" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <ui:TextBlock
                                Text="{DynamicResource LabelExtracting}"
                                FontTypography="BodyStrong" />
                        </StackPanel>
                        <ProgressBar
                            Grid.Row="1"
                            Value="{Binding ExtractionProgress}"
                            Maximum="1.0"
                            Height="6"
                            Margin="0,0,0,4" />
                        <ui:TextBlock
                            Grid.Row="2"
                            Text="{Binding ExtractionStatus}"
                            Opacity="0.65"
                            FontSize="11" />
                    </Grid>
                </ui:Card>

                <!-- ── Last result (after completion) ────────────────────────── -->
                <ui:Card
                    Visibility="{Binding ExtractionStatus, Converter={StaticResource NotEmptyToVis}}">
                    <ui:TextBlock
                        Text="{Binding ExtractionStatus}"
                        Opacity="0.65"
                        FontSize="11"
                        Visibility="{Binding IsExtracting, Converter={StaticResource InverseBoolToVis}}" />
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
