<ui:Page
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
    Scrollable="True">

    <!-- AllowDrop on the root Grid enables folder drag-and-drop anywhere on the page -->
    <Grid Margin="24,16,24,24"
          AllowDrop="True"
          DragOver="OnDragOver"
          DragEnter="OnDragEnter"
          DragLeave="OnDragLeave"
          Drop="OnDrop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Row 0: Page header ─────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBlock
                Text="{DynamicResource NavDashboard}"
                FontTypography="TitleLarge"
                Margin="0,0,16,0" />
            <ui:Button
                Content="{DynamicResource BtnRefresh}"
                Command="{Binding RefreshCommand}"
                Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                Appearance="Secondary"
                VerticalAlignment="Center" />
            <ui:ToggleButton
                Content="{DynamicResource BtnWatch}"
                IsChecked="{Binding IsWatching}"
                Command="{Binding ToggleWatchingCommand}"
                Margin="8,0,0,0"
                VerticalAlignment="Center" />
            <!-- Model-ready badge (only shown when model is loaded) -->
            <Border
                Background="#1B5E20"
                CornerRadius="4"
                Padding="8,3"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}">
                <ui:TextBlock
                    Text="{DynamicResource LabelModelLoaded}"
                    FontSize="11" />
            </Border>
        </StackPanel>

        <!-- ── Row 1: Root path ───────────────────────────────────────── -->
        <ui:Card Grid.Row="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock
                    Grid.Column="0"
                    Text="{DynamicResource LabelRootPath}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />
                <ui:TextBox
                    Grid.Column="1"
                    Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="{DynamicResource LabelDropHint}"
                    VerticalAlignment="Center" />
                <ui:Button
                    Grid.Column="2"
                    Content="{DynamicResource BtnApply}"
                    Command="{Binding ApplyRootPathCommand}"
                    Appearance="Primary"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center" />
                <!-- Open workspace root in Explorer -->
                <ui:Button
                    Grid.Column="3"
                    Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                    ToolTip="{DynamicResource BtnOpenFolder}"
                    Command="{Binding OpenFolderCommand}"
                    CommandParameter="{Binding RootPath}"
                    Appearance="Secondary"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center" />
            </Grid>
        </ui:Card>

        <!-- ── Row 2: Drag-and-drop hint (shown while dragging over page) -->
        <Border
            x:Name="DropHintBorder"
            Grid.Row="2"
            Visibility="Collapsed"
            BorderBrush="#4FC3F7"
            BorderThickness="2"
            CornerRadius="6"
            Background="#0C4FC3F7"
            Padding="12,10"
            Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="FolderArrowRight24" Margin="0,0,8,0" Foreground="#4FC3F7" />
                <ui:TextBlock
                    Text="{DynamicResource LabelDropHint}"
                    Foreground="#4FC3F7"
                    FontTypography="BodyStrong" />
            </StackPanel>
        </Border>

        <!-- ── Row 3: Extraction progress (while processing) ─────────── -->
        <ui:Card
            Grid.Row="3"
            Margin="0,0,0,12"
            Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <ui:SymbolIcon Symbol="Image24" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ui:TextBlock Text="{DynamicResource LabelExtracting}" FontTypography="BodyStrong" />
                </StackPanel>
                <ProgressBar
                    Grid.Row="1"
                    Value="{Binding ExtractionProgress}"
                    Maximum="1.0"
                    Height="6"
                    Margin="0,0,0,4" />
                <ui:TextBlock
                    Grid.Row="2"
                    Text="{Binding ExtractionStatus}"
                    Opacity="0.65"
                    FontSize="11" />
            </Grid>
        </ui:Card>

        <!-- ── Row 4: Last result status (after completion) ──────────── -->
        <ui:Card
            Grid.Row="4"
            Margin="0,0,0,12"
            Visibility="{Binding ExtractionStatus, Converter={StaticResource NotEmptyToVis}}">
            <ui:TextBlock
                Text="{Binding ExtractionStatus}"
                Opacity="0.65"
                FontSize="11"
                Visibility="{Binding IsExtracting, Converter={StaticResource InverseBoolToVis}}" />
        </ui:Card>

        <!-- ── Row 5: Pipeline folder cards ──────────────────────────── -->
        <ItemsControl Grid.Row="5" ItemsSource="{Binding FolderItems}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:FolderStatusItem}">
                    <ui:Card Margin="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Stage colour strip + role icon -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Height="4" CornerRadius="2"
                                    HorizontalAlignment="Left" Width="40"
                                    Background="{Binding StageColor}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding RoleIcon}"
                                    FontSize="18" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Folder name -->
                            <ui:TextBlock
                                Grid.Row="1"
                                Text="{Binding FolderName}"
                                FontTypography="BodyStrong"
                                Margin="0,0,0,4" />

                            <!-- PNG count -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,4,0,8">
                                <ui:TextBlock
                                    Text="{Binding FileCount}"
                                    FontSize="32" FontWeight="Bold"
                                    Foreground="{Binding StageColor}" />
                                <ui:TextBlock
                                    Text=" PNG"
                                    FontSize="14" VerticalAlignment="Bottom"
                                    Margin="4,0,0,4" Opacity="0.6" />
                            </StackPanel>

                            <!-- Open folder in Explorer -->
                            <ui:Button
                                Grid.Row="3"
                                Content="{DynamicResource BtnOpenFolder}"
                                Command="{Binding DataContext.OpenFolderCommand,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding FullPath}"
                                Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                Appearance="Secondary"
                                HorizontalAlignment="Stretch" />
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</ui:Page>
