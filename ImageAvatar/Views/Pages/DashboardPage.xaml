<UserControl
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    Background="#1C1C1E"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>

        <!-- Large blue service-toggle button (matches reference) -->
        <Style x:Key="BigBlueBtnStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#3575BE" />
            <Setter Property="Foreground"                 Value="White" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Height"                     Value="66" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4585CE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2565AE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Open-Workspace / secondary blue button -->
        <Style x:Key="MedBlueBtnStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#3575BE" />
            <Setter Property="Foreground"                 Value="White" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Height"                     Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4585CE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2565AE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon/text button for inline actions -->
        <Style x:Key="SmallActionBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#3A3A3C" />
            <Setter Property="Foreground"      Value="#CCCCCC" />
            <Setter Property="BorderBrush"     Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height"          Value="26" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A4C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid AllowDrop="True"
          DragOver="OnDragOver"
          DragEnter="OnDragEnter"
          DragLeave="OnDragLeave"
          Drop="OnDrop">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,10,12,12">

                <!-- ── Drag-drop overlay hint ───────────────────────────── -->
                <Border x:Name="DropHintBorder"
                        Visibility="Collapsed"
                        BorderBrush="#4FC3F7"
                        BorderThickness="2"
                        CornerRadius="4"
                        Background="#0C4FC3F7"
                        Padding="12,8"
                        Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource LabelDropHint}"
                               Foreground="#4FC3F7"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- ── Row 1 : Open Workspace button + path ─────────────── -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="440" />   <!-- blue button -->
                        <ColumnDefinition Width="*" />     <!-- path text -->
                        <ColumnDefinition Width="Auto" />  <!-- 浏览 -->
                        <ColumnDefinition Width="Auto" />  <!-- 应用 -->
                        <ColumnDefinition Width="Auto" />  <!-- refresh -->
                    </Grid.ColumnDefinitions>

                    <!-- Open Workspace button -->
                    <Button Grid.Column="0"
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding RootPath}"
                            Style="{StaticResource MedBlueBtnStyle}">
                        <TextBlock Text="{DynamicResource BtnOpenWorkspace}" FontSize="13" />
                    </Button>

                    <!-- Current path display -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding RootPath}"
                               Foreground="#CCCCCC"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="14,0,10,0"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Browse path -->
                    <Button Grid.Column="2"
                            Content="{DynamicResource BtnBrowse}"
                            Command="{Binding BrowseSourceFolderCommand}"
                            Style="{StaticResource SmallActionBtnStyle}"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center" />

                    <!-- Apply path -->
                    <Button Grid.Column="3"
                            Content="{DynamicResource BtnApply}"
                            Command="{Binding ApplyRootPathCommand}"
                            Style="{StaticResource SmallActionBtnStyle}"
                            Background="#3575BE"
                            BorderBrush="#3575BE"
                            Foreground="White"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center" />

                    <!-- Refresh -->
                    <Button Grid.Column="4"
                            Content="↻"
                            ToolTip="{DynamicResource BtnRefresh}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SmallActionBtnStyle}"
                            VerticalAlignment="Center" />
                </Grid>

                <!-- ── Row 2 : Auto-extraction service toggle ────────────── -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="440" />   <!-- blue button -->
                        <ColumnDefinition Width="Auto" />  <!-- status dot + text -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding ToggleWatchingCommand}"
                            Style="{StaticResource BigBlueBtnStyle}">
                        <TextBlock Text="{DynamicResource LabelToggleAutoExtractionService}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Button>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#666666" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ServiceStatusText}"
                                   FontSize="13"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                            <Setter Property="Foreground" Value="#81C784" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── Model Ready badge ──────────────────────────────────── -->
                <Border HorizontalAlignment="Left"
                        Background="#1B5E20"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="0,4,0,10"
                        Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource LabelModelLoaded}"
                               Foreground="#81C784"
                               FontSize="11" />
                </Border>

                <!-- ── Extraction progress ────────────────────────────────── -->
                <Border Background="#2A2A2C"
                        CornerRadius="3"
                        Padding="12,10"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelExtracting}"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ProgressBar Value="{Binding ExtractionProgress}"
                                     Maximum="1.0"
                                     Height="5"
                                     Margin="0,0,0,4"
                                     Foreground="#3575BE"
                                     Background="#444444" />
                        <TextBlock Text="{Binding ExtractionStatus}"
                                   Foreground="#AAAAAA"
                                   FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- ── Last result ─────────────────────────────────────────── -->
                <Border Background="#2A2A2C"
                        CornerRadius="3"
                        Padding="12,8"
                        Visibility="{Binding ExtractionStatus, Converter={StaticResource NotEmptyToVis}}">
                    <TextBlock Text="{Binding ExtractionStatus}"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               Visibility="{Binding IsExtracting, Converter={StaticResource InverseBoolToVis}}" />
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
