<UserControl
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>
        <Style x:Key="RunningDotStyle" TargetType="Ellipse">
            <Setter Property="Fill"              Value="#444444" />
            <Setter Property="Width"             Value="10" />
            <Setter Property="Height"            Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ServiceToggleBtn" TargetType="ui:Button">
            <Setter Property="Appearance"         Value="Primary" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="中控台"
                       FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,20" />

            <UniformGrid Columns="3" Rows="2">

                <!-- ══════════ Card 1 : 工作区 ══════════ -->
                <ui:Card Margin="0,0,8,8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="工作区"
                                       FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding RootPath}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding RootPath}"
                                   Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="浏览"
                                       Appearance="Secondary"
                                       Command="{Binding BrowseWorkspaceCommand}"
                                       Margin="0,0,8,0" />
                            <ui:Button Content="打开"
                                       Appearance="Primary"
                                       Command="{Binding OpenWorkspaceCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- ══════════ Card 2 : 自动裁图 ══════════ -->
                <ui:Card Margin="0,0,8,8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource RunningDotStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCropRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Crop24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="自动裁图" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Text="{Binding CropStatusText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCropRunning}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:Button Command="{Binding ToggleCropCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource ServiceToggleBtn}">
                                    <Setter Property="Content"    Value="启动服务" />
                                    <Setter Property="Appearance" Value="Primary" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCropRunning}" Value="True">
                                            <Setter Property="Content"    Value="停止服务" />
                                            <Setter Property="Appearance" Value="Danger" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

                <!-- ══════════ Card 3 : 提示词生成 ══════════ -->
                <ui:Card Margin="0,0,0,8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource RunningDotStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPromptRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Chat24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="提示词生成" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="● 未启动" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPromptRunning}" Value="True">
                                            <Setter Property="Text"       Value="● 运行中" />
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:Button Command="{Binding TogglePromptCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource ServiceToggleBtn}">
                                    <Setter Property="Content"    Value="启动服务" />
                                    <Setter Property="Appearance" Value="Primary" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPromptRunning}" Value="True">
                                            <Setter Property="Content"    Value="停止服务" />
                                            <Setter Property="Appearance" Value="Danger" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

                <!-- ══════════ Card 4 : 生图服务 ══════════ -->
                <ui:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource RunningDotStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGenRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Image24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="生图服务" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="● 未启动" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenRunning}" Value="True">
                                            <Setter Property="Text"       Value="● 运行中" />
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:Button Command="{Binding ToggleGenCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource ServiceToggleBtn}">
                                    <Setter Property="Content"    Value="启动服务" />
                                    <Setter Property="Appearance" Value="Primary" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenRunning}" Value="True">
                                            <Setter Property="Content"    Value="停止服务" />
                                            <Setter Property="Appearance" Value="Danger" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

                <!-- ══════════ Card 5 : 自动抠图 ══════════ -->
                <ui:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource RunningDotStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMattingRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Cut24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="自动抠图" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Text="{Binding MattingStatusText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMattingRunning}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:Button Command="{Binding ToggleMattingCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource ServiceToggleBtn}">
                                    <Setter Property="Content"    Value="启动服务" />
                                    <Setter Property="Appearance" Value="Primary" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMattingRunning}" Value="True">
                                            <Setter Property="Content"    Value="停止服务" />
                                            <Setter Property="Appearance" Value="Danger" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

                <!-- ══════════ Card 6 : 自动合成 ══════════ -->
                <ui:Card Margin="0,0,0,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource RunningDotStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSynthesisRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Layer24" FontSize="18" Margin="0,0,8,0" />
                            <TextBlock Text="自动合成" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Text="{Binding SynthesisStatusText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSynthesisRunning}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:Button Command="{Binding ToggleSynthesisCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource ServiceToggleBtn}">
                                    <Setter Property="Content"    Value="启动服务" />
                                    <Setter Property="Appearance" Value="Primary" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSynthesisRunning}" Value="True">
                                            <Setter Property="Content"    Value="停止服务" />
                                            <Setter Property="Appearance" Value="Danger" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
