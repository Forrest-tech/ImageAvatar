<UserControl
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <Grid AllowDrop="True"
          DragOver="OnDragOver"
          DragEnter="OnDragEnter"
          DragLeave="OnDragLeave"
          Drop="OnDrop">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24" MaxWidth="680" HorizontalAlignment="Left">

                <!-- ── Header ────────────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <ui:TextBlock
                        Text="{DynamicResource NavDashboard}"
                        FontTypography="TitleLarge"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0" />
                    <ui:Button
                        Content="{DynamicResource BtnRefresh}"
                        Command="{Binding RefreshCommand}"
                        Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                        Appearance="Secondary"
                        VerticalAlignment="Center" />
                    <Border
                        Background="#1B5E20"
                        CornerRadius="4"
                        Padding="8,3"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="12"
                                           Foreground="#81C784" Margin="0,0,5,0" />
                            <ui:TextBlock Text="{DynamicResource LabelModelLoaded}" FontSize="11" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Workspace directory ───────────────────────────────── -->
                <ui:Card Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="{DynamicResource LabelRootPath}"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0" />
                        <ui:TextBox
                            Grid.Column="1"
                            Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{DynamicResource LabelDropHint}"
                            VerticalAlignment="Center" />
                        <ui:Button
                            Grid.Column="2"
                            Content="{DynamicResource BtnBrowse}"
                            Command="{Binding BrowseSourceFolderCommand}"
                            Appearance="Secondary"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center" />
                        <ui:Button
                            Grid.Column="3"
                            Content="{DynamicResource BtnApply}"
                            Command="{Binding ApplyRootPathCommand}"
                            Appearance="Primary"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center" />
                        <ui:Button
                            Grid.Column="4"
                            Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                            ToolTip="{DynamicResource BtnOpenFolder}"
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding RootPath}"
                            Appearance="Secondary"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center" />
                    </Grid>
                </ui:Card>

                <!-- ── Open workspace button ─────────────────────────────── -->
                <ui:Button
                    Content="{DynamicResource BtnOpenWorkspace}"
                    Command="{Binding OpenFolderCommand}"
                    CommandParameter="{Binding RootPath}"
                    Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                    Appearance="Secondary"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,12"
                    Margin="0,0,0,16" />

                <!-- ── Drag-and-drop hint (shown while dragging) ─────────── -->
                <Border
                    x:Name="DropHintBorder"
                    Visibility="Collapsed"
                    BorderBrush="#4FC3F7"
                    BorderThickness="2"
                    CornerRadius="6"
                    Background="#0C4FC3F7"
                    Padding="12,10"
                    Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="FolderArrowRight24" Margin="0,0,8,0" Foreground="#4FC3F7" />
                        <ui:TextBlock
                            Text="{DynamicResource LabelDropHint}"
                            Foreground="#4FC3F7"
                            FontTypography="BodyStrong" />
                    </StackPanel>
                </Border>

                <!-- ── Services section header ───────────────────────────── -->
                <ui:TextBlock
                    Text="{DynamicResource LabelServiceSection}"
                    FontTypography="BodyStrong"
                    Opacity="0.50"
                    Margin="0,0,0,8" />

                <!-- ── Auto-extraction service card ──────────────────────── -->
                <Border
                    CornerRadius="8"
                    Margin="0,0,0,8"
                    Padding="16,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1E1E1E" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                    <Setter Property="Background" Value="#0D2A1A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Running indicator dot -->
                        <Ellipse
                            Grid.Column="0"
                            Width="10" Height="10"
                            Fill="{Binding IsWatching, Converter={StaticResource BoolToBrush}}"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0" />

                        <!-- Service name, description, status -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock
                                Text="{DynamicResource LabelAutoExtractionService}"
                                FontTypography="BodyStrong" />
                            <ui:TextBlock
                                Text="{DynamicResource LabelAutoExtractionDesc}"
                                FontSize="11"
                                Opacity="0.55"
                                Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <ui:TextBlock
                                    Text="{DynamicResource LabelStatus}"
                                    FontSize="11"
                                    Opacity="0.40"
                                    Margin="0,0,4,0" />
                                <ui:TextBlock
                                    Text="{Binding ServiceStatusText}"
                                    FontSize="11"
                                    FontWeight="SemiBold">
                                    <ui:TextBlock.Style>
                                        <Style TargetType="ui:TextBlock">
                                            <Setter Property="Foreground" Value="#777" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                                    <Setter Property="Foreground" Value="#81C784" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:TextBlock.Style>
                                </ui:TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Start / Stop toggle -->
                        <ui:Button
                            Grid.Column="2"
                            Content="{Binding ServiceToggleText}"
                            Command="{Binding ToggleWatchingCommand}"
                            Appearance="{Binding IsWatching, Converter={StaticResource BoolToAppearance}}"
                            MinWidth="90"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ── Extraction progress (while running) ───────────────── -->
                <ui:Card
                    Margin="0,0,0,10"
                    Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <ui:SymbolIcon Symbol="Image24" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <ui:TextBlock
                                Text="{DynamicResource LabelExtracting}"
                                FontTypography="BodyStrong" />
                        </StackPanel>
                        <ProgressBar
                            Grid.Row="1"
                            Value="{Binding ExtractionProgress}"
                            Maximum="1.0"
                            Height="6"
                            Margin="0,0,0,4" />
                        <ui:TextBlock
                            Grid.Row="2"
                            Text="{Binding ExtractionStatus}"
                            Opacity="0.65"
                            FontSize="11" />
                    </Grid>
                </ui:Card>

                <!-- ── Last result (after completion) ────────────────────── -->
                <ui:Card
                    Visibility="{Binding ExtractionStatus, Converter={StaticResource NotEmptyToVis}}">
                    <ui:TextBlock
                        Text="{Binding ExtractionStatus}"
                        Opacity="0.65"
                        FontSize="11"
                        Visibility="{Binding IsExtracting, Converter={StaticResource InverseBoolToVis}}" />
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
