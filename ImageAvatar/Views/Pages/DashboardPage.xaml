<UserControl
    x:Class="ImageAvatar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    Background="#1C1C1E"
    d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>

        <!-- Large blue service-toggle card – exact reference style -->
        <Style x:Key="ServiceBtnStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#3575BE" />
            <Setter Property="Foreground"                 Value="White" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Height"                     Value="68" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4585CE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2565AE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Open-workspace button: same blue, shorter -->
        <Style x:Key="WorkspaceBtnStyle" TargetType="Button"
               BasedOn="{StaticResource ServiceBtnStyle}">
            <Setter Property="Height" Value="38" />
        </Style>

    </UserControl.Resources>

    <Grid AllowDrop="True"
          DragOver="OnDragOver"
          DragEnter="OnDragEnter"
          DragLeave="OnDragLeave"
          Drop="OnDrop">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,10,12,12">

                <!-- Drag-drop hint -->
                <Border x:Name="DropHintBorder"
                        Visibility="Collapsed"
                        BorderBrush="#4FC3F7"
                        BorderThickness="2"
                        CornerRadius="3"
                        Background="#0C4FC3F7"
                        Padding="12,8"
                        Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource LabelDropHint}"
                               Foreground="#4FC3F7"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- ── Open Workspace ──────────────────────────────────── -->
                <!--
                    Left column  = 6* ≈ 46 % of window width  (button)
                    Right column = 7* ≈ 54 % (path text + small actions)
                -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding RootPath}"
                            Style="{StaticResource WorkspaceBtnStyle}">
                        <TextBlock Text="{DynamicResource BtnOpenWorkspace}" FontSize="13" />
                    </Button>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="{Binding RootPath}"
                                   Foreground="#CCCCCC"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="360" />
                        <!-- small change-path button tucked after path text -->
                        <Button Content="…"
                                ToolTip="{DynamicResource BtnBrowse}"
                                Command="{Binding BrowseSourceFolderCommand}"
                                Foreground="#888888"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="8,0,0,0"
                                Padding="4,0"
                                Height="22"
                                FontSize="14"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}" />
                    </StackPanel>
                </Grid>

                <!-- ── Auto-extraction service ────────────────────────── -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding ToggleWatchingCommand}"
                            Style="{StaticResource ServiceBtnStyle}">
                        <TextBlock Text="{DynamicResource LabelToggleAutoExtractionService}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Button>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                        <Ellipse Width="9" Height="9"
                                 VerticalAlignment="Center"
                                 Margin="0,0,7,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#555555" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ServiceStatusText}"
                                   FontSize="13"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                            <Setter Property="Foreground" Value="#81C784" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── Model ready badge ──────────────────────────────── -->
                <Border HorizontalAlignment="Left"
                        Background="#1B5E20"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="0,2,0,10"
                        Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource LabelModelLoaded}"
                               Foreground="#81C784"
                               FontSize="11" />
                </Border>

                <!-- ── Extraction progress ────────────────────────────── -->
                <Border Background="#2A2A2C"
                        CornerRadius="3"
                        Padding="12,10"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelExtracting}"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ProgressBar Value="{Binding ExtractionProgress}"
                                     Maximum="1.0"
                                     Height="5"
                                     Margin="0,0,0,4"
                                     Foreground="#3575BE"
                                     Background="#444444" />
                        <TextBlock Text="{Binding ExtractionStatus}"
                                   Foreground="#AAAAAA"
                                   FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- ── Last result ────────────────────────────────────── -->
                <Border Background="#2A2A2C"
                        CornerRadius="3"
                        Padding="12,8"
                        Visibility="{Binding ExtractionStatus, Converter={StaticResource NotEmptyToVis}}">
                    <TextBlock Text="{Binding ExtractionStatus}"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               Visibility="{Binding IsExtracting, Converter={StaticResource InverseBoolToVis}}" />
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
