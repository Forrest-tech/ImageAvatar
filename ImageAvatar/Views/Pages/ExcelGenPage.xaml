<UserControl
    x:Class="ImageAvatar.Views.Pages.ExcelGenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:ExcelGenViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: parameters ── -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="上品 Excel 生成" FontSize="22" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="来源文件夹" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding SourceFolder}"
                                        IsReadOnly="True"
                                        PlaceholderText="包含成品图的文件夹" />
                            <ui:Button Grid.Column="2" Content="浏览"
                                       Appearance="Secondary"
                                       Command="{Binding BrowseSourceCommand}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="输出文件" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding OutputPath}"
                                        IsReadOnly="True"
                                        PlaceholderText="输出 .xlsx 路径" />
                            <ui:Button Grid.Column="2" Content="另存为"
                                       Appearance="Secondary"
                                       Command="{Binding BrowseOutputCommand}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="生成 Excel"
                               Appearance="Primary"
                               Command="{Binding GenerateCommand}"
                               Margin="0,0,12,0" />
                    <ui:ProgressRing IsIndeterminate="True"
                                    Width="22" Height="22"
                                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- ── Right: info panel ── -->
            <ui:Card Grid.Column="2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="说明" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="扫描成品文件夹中的图片，按 SPU 全局配置生成上品清单 Excel 文件。&#x0a;&#x0a;Excel 中包含：文件名、尺寸、SPU 编号、生成时间。&#x0a;&#x0a;需先在「全局配置」中设置文件命名规则。" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
