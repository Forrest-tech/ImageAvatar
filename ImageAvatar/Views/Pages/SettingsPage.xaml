<UserControl
    x:Class="ImageAvatar.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,16,24,24" MaxWidth="620" HorizontalAlignment="Left">

        <ui:TextBlock
            Text="{DynamicResource NavSettings}"
            FontTypography="TitleLarge"
            Margin="0,0,0,24" />

        <!-- ── AI Model ──────────────────────────────────────────────── -->
        <ui:CardExpander
            Header="{DynamicResource SettingsModelHeader}"
            Icon="{ui:SymbolIcon Symbol=Bot24}"
            IsExpanded="True"
            Margin="0,0,0,12">
            <StackPanel Margin="0,8,0,0">

                <ui:TextBlock
                    Text="{DynamicResource SettingsModelDesc}"
                    Opacity="0.7"
                    Margin="0,0,0,10" />

                <!-- Model path row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox
                        Grid.Column="0"
                        Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="%AppData%\ImageAvatar\models\u2net.onnx"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Content="{DynamicResource BtnBrowse}"
                        Command="{Binding BrowseModelCommand}"
                        Appearance="Secondary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="2"
                        Content="{DynamicResource BtnLoadModel}"
                        Command="{Binding LoadModelCommand}"
                        Appearance="Primary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>

                <!-- Status row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon
                        Symbol="Checkmark24"
                        Foreground="#4CAF50"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsModelLoaded, Converter={StaticResource BoolToVis}}" />
                    <ui:SymbolIcon
                        Symbol="ErrorCircle24"
                        Foreground="#F44336"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsModelLoaded, Converter={StaticResource InverseBoolToVis}}" />
                    <ui:TextBlock
                        Text="{Binding ModelStatus}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                    <ui:ProgressRing
                        IsIndeterminate="True"
                        Width="16" Height="16"
                        Visibility="{Binding IsLoadingModel, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!-- Download hint -->
                <ui:TextBlock
                    Text="{DynamicResource SettingsModelHint}"
                    Opacity="0.5"
                    FontSize="11" />
            </StackPanel>
        </ui:CardExpander>

        <!-- ── Language ──────────────────────────────────────────────── -->
        <ui:CardExpander
            Header="{DynamicResource SettingsLanguageHeader}"
            Icon="{ui:SymbolIcon Symbol=LocalLanguage24}"
            IsExpanded="True"
            Margin="0,0,0,12">
            <StackPanel Margin="0,8,0,0">
                <ui:TextBlock
                    Text="{DynamicResource SettingsLanguageDesc}"
                    Opacity="0.7"
                    Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        Grid.Column="0"
                        ItemsSource="{Binding SupportedLanguages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Content="{DynamicResource BtnApply}"
                        Command="{Binding ApplyLanguageCommand}"
                        Appearance="Primary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <!-- ── Theme ─────────────────────────────────────────────────── -->
        <ui:CardExpander
            Header="{DynamicResource SettingsThemeHeader}"
            Icon="{ui:SymbolIcon Symbol=PaintBrush24}"
            IsExpanded="True">
            <StackPanel Margin="0,8,0,0">
                <ui:TextBlock
                    Text="{DynamicResource SettingsThemeDesc}"
                    Opacity="0.7"
                    Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        Grid.Column="0"
                        ItemsSource="{Binding ThemeNames}"
                        SelectedIndex="{Binding SelectedThemeIndex}"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Content="{DynamicResource BtnApply}"
                        Command="{Binding ApplyThemeCommand}"
                        Appearance="Primary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

    </StackPanel>
    </ScrollViewer>
</UserControl>
