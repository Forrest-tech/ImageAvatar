<ui:Page
    x:Class="ImageAvatar.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    Scrollable="True">

    <StackPanel Margin="24,16,24,24" MaxWidth="600" HorizontalAlignment="Left">

        <!-- Page Header -->
        <ui:TextBlock
            Text="{DynamicResource NavSettings}"
            FontTypography="TitleLarge"
            Margin="0,0,0,24" />

        <!-- Language Section -->
        <ui:CardExpander
            Header="{DynamicResource SettingsLanguageHeader}"
            Icon="{ui:SymbolIcon Symbol=LocalLanguage24}"
            IsExpanded="True"
            Margin="0,0,0,12">
            <StackPanel Margin="0,8,0,0">
                <ui:TextBlock
                    Text="{DynamicResource SettingsLanguageDesc}"
                    Opacity="0.7"
                    Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        Grid.Column="0"
                        ItemsSource="{Binding SupportedLanguages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Content="{DynamicResource BtnApply}"
                        Command="{Binding ApplyLanguageCommand}"
                        Appearance="Primary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <!-- Theme Section -->
        <ui:CardExpander
            Header="{DynamicResource SettingsThemeHeader}"
            Icon="{ui:SymbolIcon Symbol=PaintBrush24}"
            IsExpanded="True">
            <StackPanel Margin="0,8,0,0">
                <ui:TextBlock
                    Text="{DynamicResource SettingsThemeDesc}"
                    Opacity="0.7"
                    Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        Grid.Column="0"
                        ItemsSource="{Binding ThemeNames}"
                        SelectedIndex="{Binding SelectedThemeIndex}"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Content="{DynamicResource BtnApply}"
                        Command="{Binding ApplyThemeCommand}"
                        Appearance="Primary"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

    </StackPanel>
</ui:Page>
