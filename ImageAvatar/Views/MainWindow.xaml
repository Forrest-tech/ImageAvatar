<Window
    x:Class="ImageAvatar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:ImageAvatar.Views.Pages"
    mc:Ignorable="d"
    Title="ImageAvatar"
    Width="1280"
    Height="760"
    MinWidth="960"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E">

    <Grid>
        <ui:NavigationView
            x:Name="RootNavigation"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed">

            <ui:NavigationView.MenuItems>

                <ui:NavigationViewItem
                    Content="中控台"
                    TargetPageType="{x:Type pages:DashboardPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="全局配置"
                    TargetPageType="{x:Type pages:GlobalConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="自动裁剪"
                    TargetPageType="{x:Type pages:CropConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Crop24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="提示词配置"
                    TargetPageType="{x:Type pages:PromptConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Chat24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="生图服务"
                    TargetPageType="{x:Type pages:GenConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Image24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="自动抠图"
                    TargetPageType="{x:Type pages:MattingConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Cut24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="自动合成"
                    TargetPageType="{x:Type pages:SynthesisConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Layer24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Excel 生成"
                    TargetPageType="{x:Type pages:ExcelGenPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DocumentTable24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="控制台"
                    TargetPageType="{x:Type pages:ConsolePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Braces24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

            </ui:NavigationView.MenuItems>

        </ui:NavigationView>
    </Grid>
</Window>
