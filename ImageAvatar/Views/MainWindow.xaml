<ui:FluentWindow
    x:Class="ImageAvatar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ImageAvatar.ViewModels"
    mc:Ignorable="d"
    Title="{Binding AppTitle}"
    Width="1024"
    Height="680"
    MinWidth="800"
    MinHeight="500"
    ExtendsContentIntoTitleBar="True"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="{DynamicResource AppTitle}"
            Icon="pack://application:,,,/Assets/app.png">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- NavigationView -->
        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsPaneOpen="True"
            OpenPaneLength="220"
            Loaded="OnNavigationViewLoaded">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    x:Name="NavDashboard"
                    Content="{DynamicResource NavDashboard}"
                    Icon="{ui:SymbolIcon Symbol=Grid24}"
                    TargetPageType="{x:Type local:DashboardPage}"
                    xmlns:local="clr-namespace:ImageAvatar.Views.Pages" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    x:Name="NavSettings"
                    Content="{DynamicResource NavSettings}"
                    Icon="{ui:SymbolIcon Symbol=Settings24}"
                    TargetPageType="{x:Type local:SettingsPage}"
                    xmlns:local="clr-namespace:ImageAvatar.Views.Pages" />
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
